{
  "name": "minecraft-chess-ai",
  "version": "1.0.0",
  "description": "An MCP client that connects to Minecraft to play chess using a Minecraft MCP server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "setup-server": "node scripts/setup-server.js",
    "start-server": "node scripts/start-server.js",
    "start-live": "tsx src/index.ts --port 25565 --username ChessBot",
    "start-bot": "tsx src/ai-bot.ts"
  },
  "dependencies": {
    "openai": "^4.73.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chess.js": "^1.0.0-beta.6",
    "mineflayer": "^4.37.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.20",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
